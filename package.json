  },
  "homepage": "https://github.com/ChristianTrentsch/BrowserGames#readme",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "esbuild": "0.28.0",
    "eslint": "10.4.1",
    "globals": "17.6.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.3"
  }
